NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SESSION_SECRET=your-random-secret-at-least-32-chars

# Public site URL (used for absolute URL generation)
# Local: http://localhost:3000 | Staging: https://your-app-git-staging.vercel.app | Prod: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: session lifetime in hours (default: 24)
# SESSION_DURATION_HOURS=24

# Optional: rate limiting for login (defaults shown)
# RATE_LIMIT_WINDOW_MINUTES=15
# RATE_LIMIT_MAX_ATTEMPTS=5

# Password reset email provider (see lib/mailer.ts)
# In development the reset link is logged to the console instead of sent.
# RESEND_API_KEY=re_xxxx   # example: Resend provider
